<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>dorkator — interactive dork library</title>
<meta name="description" content="OSINT dork library — set your target and get clickable Google / DuckDuckGo / Bing links for {{ total }} curated dorks.">
<style>
  /* Reset + base ------------------------------------------------------ */
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }

  :root {
    --bg:        #fafaf7;
    --surface:   #ffffff;
    --border:    #e3e3df;
    --border-2:  #c9c9c2;
    --text:      #1a1a1a;
    --text-2:    #555;
    --text-3:    #888;
    --accent:    #1d4ed8;
    --critical:  #b91c1c;
    --high:      #c2410c;
    --medium:    #a16207;
    --low:       #15803d;
    --info:      #6b7280;
    --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .wrap { max-width: 880px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }

  /* Header ------------------------------------------------------------ */
  header { margin-bottom: 1.75rem; }
  h1 {
    font-family: var(--mono);
    font-size: 1.45rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  h1 .v { color: var(--text-3); font-weight: 400; font-size: 0.85rem; margin-left: 0.4rem; }
  .sub { color: var(--text-2); margin: 0 0 0.5rem; font-size: 0.92rem; }
  .stats {
    color: var(--text-3); font-size: 0.8rem; font-family: var(--mono);
  }
  .stats .sep { padding: 0 0.45rem; color: var(--border-2); }

  /* Legal note -------------------------------------------------------- */
  .legal {
    margin: 1.25rem 0 1.5rem;
    padding: 0.55rem 0.8rem;
    border-left: 2px solid var(--medium);
    background: #fffbe6;
    color: #5b4a00;
    font-size: 0.82rem;
    border-radius: 0 4px 4px 0;
  }

  /* Target input ------------------------------------------------------ */
  .target-row {
    display: flex; align-items: center; gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .target-row label {
    font-family: var(--mono); font-size: 0.85rem;
    color: var(--text-2); flex-shrink: 0;
  }
  #target {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border-2);
    color: var(--text);
    padding: 0.55rem 0.7rem;
    border-radius: 4px;
    font-family: var(--mono);
    font-size: 0.92rem;
  }
  #target:focus { outline: 2px solid var(--accent); outline-offset: -1px; border-color: var(--accent); }
  .target-hint { color: var(--text-3); font-size: 0.78rem; margin: -0.4rem 0 1.25rem; padding-left: 0.1rem; }

  /* Filters ----------------------------------------------------------- */
  .filters {
    display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;
    margin-bottom: 1.5rem; padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  #search {
    flex: 1; min-width: 200px;
    background: var(--surface);
    border: 1px solid var(--border-2);
    color: var(--text);
    padding: 0.45rem 0.65rem;
    border-radius: 4px;
    font-family: var(--sans); font-size: 0.85rem;
  }
  #search:focus { outline: 2px solid var(--accent); outline-offset: -1px; border-color: var(--accent); }
  .pills { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .pill {
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--border-2);
    background: var(--surface);
    color: var(--text-2);
    font-family: var(--mono); font-size: 0.72rem;
    border-radius: 4px;
    cursor: pointer; user-select: none;
    text-transform: lowercase;
  }
  .pill:hover { border-color: var(--text-2); color: var(--text); }
  .pill.active { background: var(--text); color: var(--bg); border-color: var(--text); }

  /* Categories -------------------------------------------------------- */
  .category {
    margin-bottom: 1.5rem;
  }
  .category-h {
    display: flex; align-items: baseline; gap: 0.55rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
    cursor: pointer; user-select: none;
  }
  .category-h:hover .name { color: var(--accent); }
  .category-h .key {
    font-family: var(--mono); font-size: 0.78rem; color: var(--text-3);
  }
  .category-h .name {
    font-weight: 600; font-size: 0.95rem;
  }
  .category-h .count {
    margin-left: auto;
    font-family: var(--mono); font-size: 0.75rem; color: var(--text-3);
  }
  .category-h .chev { color: var(--text-3); font-size: 0.7rem; transition: transform 0.15s; margin-left: 0.45rem; }
  .category.collapsed .chev { transform: rotate(-90deg); }
  .category.collapsed .body { display: none; }

  /* Dork -------------------------------------------------------------- */
  .dork { padding: 0.65rem 0; }
  .dork + .dork { border-top: 1px solid var(--border); }
  .dork-head {
    display: flex; align-items: baseline; gap: 0.55rem;
    margin-bottom: 0.35rem; flex-wrap: wrap;
  }
  .sev {
    font-family: var(--mono); font-size: 0.66rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.4px;
    padding: 1px 6px; border-radius: 3px; flex-shrink: 0;
  }
  .sev.critical { background: #fee2e2; color: var(--critical); }
  .sev.high     { background: #ffedd5; color: var(--high); }
  .sev.medium   { background: #fef3c7; color: var(--medium); }
  .sev.low      { background: #dcfce7; color: var(--low); }
  .sev.info     { background: #f3f4f6; color: var(--info); }
  .dork-name { font-weight: 500; flex: 1; min-width: 200px; color: var(--text); font-size: 0.9rem; }
  .dork-query {
    font-family: var(--mono); font-size: 0.78rem;
    background: #f5f5ef;
    color: #2a2a2a;
    padding: 0.5rem 0.65rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    word-break: break-all;
    margin: 0.35rem 0 0.45rem;
  }
  .dork-links {
    display: flex; gap: 0.4rem; flex-wrap: wrap;
    font-size: 0.78rem;
  }
  .dork-links a {
    color: var(--accent);
  }
  .dork-links a + a::before {
    content: "·"; color: var(--text-3); margin-right: 0.4rem;
    text-decoration: none;
  }
  .dork-links a.disabled {
    pointer-events: none; opacity: 0.4; color: var(--text-3);
    text-decoration: none;
  }

  /* Misc -------------------------------------------------------------- */
  .hidden { display: none !important; }
  .no-results {
    text-align: center; padding: 2rem;
    color: var(--text-3); font-size: 0.88rem;
    border: 1px dashed var(--border-2);
    border-radius: 4px;
    display: none;
  }
  .no-results.show { display: block; }

  footer {
    margin-top: 3rem; padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--text-3); font-size: 0.78rem;
  }

  ::selection { background: var(--accent); color: #fff; }
</style>
</head>
<body>

<div class="wrap">

  <header>
    <h1>dorkator<span class="v">v0.3</span></h1>
    <p class="sub">An interactive OSINT dork library. Set a target, copy a query, or open it in Google / DuckDuckGo / Bing.</p>
    <div class="stats">
      {{ total }} dorks <span class="sep">·</span>
      {{ categories|length }} categories <span class="sep">·</span>
      built {{ generated_at }}
    </div>
  </header>

  <div class="legal">
    <strong>Legal notice.</strong> These queries hit public search indexes only.
    Run them against assets you own or are explicitly authorized to test.
  </div>

  <div class="target-row">
    <label for="target">target&nbsp;&gt;</label>
    <input type="text" id="target" placeholder="example.com" autocomplete="off" autofocus spellcheck="false">
  </div>
  <div class="target-hint">Type a domain — every query and search-engine link below updates live. Saved locally for next visit.</div>

  <div class="filters">
    <input type="text" id="search" placeholder="filter by name or query…" autocomplete="off">
    <div class="pills" id="sev-filter">
      <span class="pill active" data-sev="all">all</span>
      <span class="pill" data-sev="critical">critical</span>
      <span class="pill" data-sev="high">high</span>
      <span class="pill" data-sev="medium">medium</span>
      <span class="pill" data-sev="low">low</span>
      <span class="pill" data-sev="info">info</span>
    </div>
  </div>

  <div id="results">
  {% for cat in categories %}
  <section class="category" data-category="{{ cat.key }}">
    <div class="category-h" onclick="this.parentElement.classList.toggle('collapsed')">
      <span class="key">{{ cat.key }}/</span>
      <span class="name">{{ cat.name }}</span>
      <span class="count">{{ cat.dorks|length }}</span>
      <span class="chev">▾</span>
    </div>
    <div class="body">
      {% for d in cat.dorks %}
      <div class="dork"
           data-sev="{{ d.severity }}"
           data-raw-query="{{ d.query }}"
           data-name="{{ d.name|lower }}">
        <div class="dork-head">
          <span class="sev {{ d.severity }}">{{ d.severity }}</span>
          <span class="dork-name">{{ d.name }}</span>
        </div>
        <div class="dork-query">{{ d.query }}</div>
        <div class="dork-links">
          <a class="link-google" href="#" target="_blank" rel="noopener">Google</a>
          <a class="link-ddg" href="#" target="_blank" rel="noopener">DuckDuckGo</a>
          <a class="link-bing" href="#" target="_blank" rel="noopener">Bing</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endfor %}
  </div>

  <div class="no-results" id="no-results">No dorks match your filters.</div>

  <footer>
    <a href="https://github.com/twux-sec/dorkator">github.com/twux-sec/dorkator</a> · MIT · Use responsibly.
  </footer>

</div>

<script>
  // State -------------------------------------------------------------
  const targetInput = document.getElementById('target');
  const searchInput = document.getElementById('search');
  const sevPills    = document.querySelectorAll('.pill');
  const noResults   = document.getElementById('no-results');
  const dorks       = document.querySelectorAll('.dork');

  let activeSev = 'all';

  // Search-engine URL builders (mirror Python core.Dork properties)
  const ENGINES = {
    google: q => 'https://www.google.com/search?q=' + encodeURIComponent(q),
    ddg:    q => 'https://duckduckgo.com/?q='     + encodeURIComponent(q),
    bing:   q => 'https://www.bing.com/search?q=' + encodeURIComponent(q),
  };

  const STORAGE_KEY = 'dorkator.target';

  // Live rewriting ----------------------------------------------------
  function applyTarget(raw) {
    const t = raw.trim();
    const display = t || '{target}';
    const linksLive = Boolean(t);

    dorks.forEach(d => {
      const rawQuery = d.dataset.rawQuery;
      const rendered = rawQuery.replaceAll('{target}', display);

      d.querySelector('.dork-query').textContent = rendered;

      const linkG = d.querySelector('.link-google');
      const linkD = d.querySelector('.link-ddg');
      const linkB = d.querySelector('.link-bing');

      if (linksLive) {
        linkG.href = ENGINES.google(rendered);
        linkD.href = ENGINES.ddg(rendered);
        linkB.href = ENGINES.bing(rendered);
        linkG.classList.remove('disabled');
        linkD.classList.remove('disabled');
        linkB.classList.remove('disabled');
      } else {
        linkG.href = '#'; linkD.href = '#'; linkB.href = '#';
        linkG.classList.add('disabled');
        linkD.classList.add('disabled');
        linkB.classList.add('disabled');
      }

      d.dataset.text = (d.dataset.name + ' ' + rendered).toLowerCase();
    });

    if (t) localStorage.setItem(STORAGE_KEY, t);
    else   localStorage.removeItem(STORAGE_KEY);

    applyFilters();
  }

  // Filters -----------------------------------------------------------
  function applyFilters() {
    const q = searchInput.value.toLowerCase().trim();
    let totalVisible = 0;

    document.querySelectorAll('.category').forEach(cat => {
      let visible = 0;
      cat.querySelectorAll('.dork').forEach(d => {
        const matchesSev  = activeSev === 'all' || d.dataset.sev === activeSev;
        const matchesText = !q || (d.dataset.text || '').includes(q);
        const show = matchesSev && matchesText;
        d.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      cat.classList.toggle('hidden', visible === 0);
      totalVisible += visible;
    });

    noResults.classList.toggle('show', totalVisible === 0);
  }

  // Events ------------------------------------------------------------
  targetInput.addEventListener('input', e => applyTarget(e.target.value));
  searchInput.addEventListener('input', applyFilters);
  sevPills.forEach(p => p.addEventListener('click', () => {
    sevPills.forEach(x => x.classList.remove('active'));
    p.classList.add('active');
    activeSev = p.dataset.sev;
    applyFilters();
  }));

  // "/" focuses the search input from anywhere
  document.addEventListener('keydown', e => {
    if (e.key === '/' && document.activeElement !== searchInput
                      && document.activeElement !== targetInput) {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // Boot --------------------------------------------------------------
  const restored = localStorage.getItem(STORAGE_KEY) || '';
  if (restored) targetInput.value = restored;
  applyTarget(targetInput.value);
</script>

</body>
</html>
